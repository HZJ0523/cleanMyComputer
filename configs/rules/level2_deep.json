[
  {
    "id": "windows_old",
    "name": "Windows.old 文件夹",
    "category": "system",
    "level": 2,
    "description": "清理系统升级后遗留的旧版本文件夹",
    "targets": [
      {
        "type": "folder",
        "path": "C:\\Windows.old",
        "pattern": "*",
        "recursive": true,
        "max_depth": 5,
        "exclude_list": []
      }
    ],
    "risk_score": 40,
    "requires_admin": true,
    "enabled": true
  },
  {
    "id": "font_cache",
    "name": "字体缓存",
    "category": "system",
    "level": 2,
    "description": "清理 Windows 字体缓存文件",
    "targets": [
      {
        "type": "folder",
        "path": "C:\\Windows\\ServiceProfiles\\LocalService\\AppData\\Local\\FontCache",
        "pattern": "*.dat",
        "recursive": false,
        "max_depth": 0,
        "exclude_list": ["Fntcache.dat"]
      }
    ],
    "risk_score": 30,
    "requires_admin": true,
    "enabled": true
  },
  {
    "id": "windows_store_cache",
