      {
        "type": "folder",
        "path": "%TEMP%",
        "pattern": "~*.tmp",
        "recursive": false,
        "max_depth": 0,
        "exclude_list": []
      }
    ],
    "risk_score": 25,
    "requires_admin": false,
    "enabled": true
  },
