  {
    "id": "downloads_old",
    "name": "下载文件夹旧文件",
    "category": "user",
    "level": 2,
    "description": "扫描下载文件夹中超过30天的文件",
    "targets": [
      {
        "type": "folder",
        "path": "%USERPROFILE%\\Downloads",
        "pattern": "*",
        "recursive": true,
        "max_depth": 2,
        "exclude_list": ["*.crdownload", "*.part"]
      }
    ],
    "risk_score": 45,
    "requires_admin": false,
    "enabled": false
  },
  {
