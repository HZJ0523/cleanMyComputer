[
  {
    "id": "system_logs",
    "name": "系统日志文件",
    "category": "system",
    "level": 3,
    "description": "清理 Windows 系统日志文件",
    "targets": [
      {
        "type": "folder",
        "path": "C:\\Windows\\Logs",
        "pattern": "*.log",
        "recursive": true,
        "max_depth": 3,
        "exclude_list": []
      }
    ],
    "risk_score": 70,
    "requires_admin": true,
    "enabled": false
  },
  {
    "id": "hibernation_file",
    "name": "休眠文件",
    "category": "system",
    "level": 3,
    "description": "关闭休眠功能以删除 hiberfil.sys",
    "targets": [
      {
        "type": "command",
        "path": "powercfg /hibernate off",
        "pattern": "",
        "recursive": false,
        "max_depth": 0,
        "exclude_list": []
      }
    ],
    "risk_score": 80,
    "requires_admin": true,
    "enabled": false
  },
  {
    "id": "dev_node_modules",
    "name": "node_modules 目录",
    "category": "dev",
    "level": 3,
    "description": "扫描用户目录中的 node_modules 目录",
    "targets": [
      {
        "type": "folder",
        "path": "%USERPROFILE%",
        "pattern": "node_modules",
        "recursive": true,
        "max_depth": 5,
        "exclude_list": []
      }
    ],
    "risk_score": 65,
    "requires_admin": false,
    "enabled": false
  },
  {
    "id": "dev_build_outputs",
    "name": "构建输出目录",
    "category": "dev",
    "level": 3,
    "description": "扫描用户目录中的 build/dist 输出目录",
    "targets": [
      {
        "type": "folder",
        "path": "%USERPROFILE%",
        "pattern": "build",
        "recursive": true,
        "max_depth": 4,
        "exclude_list": []
      },
      {
        "type": "folder",
        "path": "%USERPROFILE%",
        "pattern": "dist",
        "recursive": true,
        "max_depth": 4,
        "exclude_list": []
      }
    ],
    "risk_score": 70,
    "requires_admin": false,
    "enabled": false
  },
  {
    "id": "docker_cleanup",
    "name": "Docker 未使用资源",
    "category": "dev",
    "level": 3,
    "description": "清理 Docker 未使用的镜像和容器",
    "targets": [
      {
        "type": "command",
        "path": "docker system prune -f",
        "pattern": "",
        "recursive": false,
        "max_depth": 0,
        "exclude_list": []
      }
    ],
    "risk_score": 75,
    "requires_admin": false,
    "enabled": false
  }
]
