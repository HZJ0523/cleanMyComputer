  {
    "id": "temp_files",
    "name": "临时文件",
    "category": "system",
    "level": 1,
    "description": "清理用户临时文件夹中的文件",
    "targets": [
      {
        "type": "folder",
        "path": "%TEMP%",
        "pattern": "*",
        "recursive": true,
        "max_depth": 5,
        "exclude_list": ["*.lock", "*.tmp.lock"]
      },
      {
        "type": "folder",
        "path": "C:\\Windows\\Temp",
        "pattern": "*",
        "recursive": true,
        "max_depth": 3,
        "exclude_list": ["*.lock"]
      }
    ],
    "risk_score": 10,
    "requires_admin": false,
    "enabled": true
  },
